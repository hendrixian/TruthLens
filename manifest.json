{
  "manifest_version": 3,
  "name": "Right Sidebar",
  "version": "1.0",
  "description": "Toggle sidebar with floating icon",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["img/TruthLens.png"],
      "matches": ["<all_urls>"]
    }
  ]
}